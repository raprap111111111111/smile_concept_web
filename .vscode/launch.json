{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flutter: Run Web (Fixed Port 8080)",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "cwd": "${workspaceFolder}",
            "flutterMode": "debug",
            "args": [
                "--web-port=8080"
            ]
        },
        {
            "name": "Flutter: Run App (Mobile)",
            "type": "dart",
            "request": "launch",
            "program": "lib/main.dart",
            "cwd": "${workspaceFolder}",
            "flutterMode": "debug"
        },
        {
            "name": "Flutter: Run Tests",
            "type": "dart",
            "request": "launch",
            "program": "test/",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Launch Chrome against localhost",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        }
    ]
}